{
  "name": "atithi-llp-desktop",
  "version": "1.0.1",
  "description": "Atithi LLP HR Management Desktop Application",
  "main": "launcher.js",
  "private": true,
  "type": "module",
  "workspaces": [
    "frontend",
    "Backend"
  ],
  "scripts": {
    "frontend": "npm run dev --workspace frontend",
    "backend": "npm run dev --workspace Backend",
    "build:desktop": "node build-desktop.js",
    "start:desktop": "node launcher.js",
    "package": "pkg . --out-path dist/",
    "clean": "rimraf frontend/.next Backend/node_modules node_modules dist",
    "setup:env": "node Backend/scripts/setup-secure-env.js",
    "secure:env": "node Backend/scripts/secure-env.js",
    "deploy:production": "node Backend/scripts/deploy-production.js",
    "health:check": "curl http://localhost:8000/api/health/full",
    "docs:generate": "node docs/generate-docs-simple.js",
    "docs:sdd": "node docs/generate-sdd.js",
    "docs:serve": "node docs/serve-docs.js",
    "docs:manual": "cd docs/user-manual && python -m http.server 8081",
    "docs:build": "npm run docs:generate && echo 'Complete documentation generated successfully'",
    "build:render": "npm run build --workspace frontend && node Backend/scripts/build-frontend.js",
    "start:render": "npm run start --workspace Backend",
    "build:backend": "npm run build --workspace Backend",
    "start:backend": "npm run start --workspace Backend"
  },
  "bin": "launcher.js",
  "pkg": {
    "scripts": [
      "Backend/src/**/*.js",
      "production-server.js",
      "launcher.js"
    ],
    "assets": [
      "frontend/.next/**/*",
      "frontend/public/**/*",
      "Backend/src/**/*",
      "Backend/fonts/**/*",
      "Backend/public/**/*"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "dist/"
  },
  "dependencies": {
    "axios": "^1.13.1",
    "bcrypt": "^5.1.1",
    "bwip-js": "^4.7.0",
    "cloudinary": "^2.6.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "form-data": "^4.0.4",
    "html2pdf.js": "^0.10.3",
    "http-proxy-middleware": "^2.0.6",
    "jsbarcode": "^3.12.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.6",
    "mongoose-aggregate-paginate-v2": "^1.1.3",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "nodemon": "^3.1.9",
    "pdfkit": "^0.17.1",
    "pdfmake": "^0.2.20",
    "pkg": "^5.8.1",
    "prettier": "^3.4.2",
    "puppeteer": "^24.11.2",
    "react-barcode": "^1.6.1",
    "rimraf": "^5.0.5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/html2pdf.js": "^0.10.0",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "postcss": "^8.5",
    "tailwindcss": "^3.4.17",
    "typescript": "^5"
  }
}