  }
};

export const recordPunch = async (req, res) => {
  try {
    const { employeeId, punchType, base64Image } = req.body;
    if (!employeeId || !punchType || !base64Image) {
      return res.status(400).json({ error: "Missing fields" });
    }

    // Try to find as employee
