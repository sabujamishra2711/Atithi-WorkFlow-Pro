export const deletePunch = async (req, res) => {
  try {
    const { id } = req.params;
    // Find the session by ID
    const session = await AttendanceSession.findById(id);
    if (!session) {
      return res.status(404).json({ error: "Session not found" });
    }
    
    // Delete the session record
    await AttendanceSession.findByIdAndDelete(id);
    
    return res.status(200).json({ message: "Session deleted successfully", session });
  } catch (err) {
    console.error("Error deleting session:", err);
    return res.status(500).json({ error: "Server error" });
  }
};

export const getPunchesByDate = async (req, res) => {
  try {
    const { date } = req.query;
    if (!date) return res.status(400).json({ error: "Missing date query param (YYYY-MM-DD)" });
    const start = new Date(date + 'T00:00:00.000Z');
    const end = new Date(date + 'T23:59:59.999Z');
    const sessions = await AttendanceSession.find({ 
      $or: [
        { inTime: { $gte: start, $lte: end } },
        { outTime: { $gte: start, $lte: end } }
      ]
    });
    console.log("[DEBUG] Date filter (UTC):", { start, end });
    sessions.forEach(s => console.log("[DEBUG] Session times:", { inTime: s.inTime, outTime: s.outTime }));
    res.status(200).json({ data: sessions });
  } catch (err) {
    console.error("Error fetching sessions by date:", err);
    res.status(500).json({ error: "Server error" });
  }
};

// Get recent manual punches for a given date
export const getRecentManualPunchesByDate = async (req, res) => {
  try {
    const { date } = req.query;
    if (!date) return res.status(400).json({ error: "Missing date query param (YYYY-MM-DD)" });
    const start = new Date(date + 'T00:00:00.000Z');
    const end = new Date(date + 'T23:59:59.999Z');
    // Manual sessions: those with a non-empty reason
    const sessions = await AttendanceSession.find({
      inTime: { $gte: start, $lte: end },
      reason: { $exists: true, $ne: null, $ne: "" }
    }).sort({ inTime: -1 });
    res.status(200).json({ data: sessions });
  } catch (err) {
    console.error("Error fetching recent manual sessions by date:", err);
    res.status(500).json({ error: "Server error" });
  }
};

// New function to get daily attendance with night shift handling
export const getDailyAttendanceWithNightShift = async (req, res) => {
  try {
    const { date } = req.query;
    if (!date) return res.status(400).json({ error: "Missing date query param (YYYY-MM-DD)" });
    
    const targetDate = new Date(date);
    // Extend the range to catch night shift punches
    const start = new Date(targetDate);
    start.setDate(start.getDate() - 1); // Start from previous day
    start.setHours(0, 0, 0, 0);
    
    const end = new Date(targetDate);
    end.setDate(end.getDate() + 1); // End at next day
    end.setHours(23, 59, 59, 999);
    
    // Get all sessions in the extended range to properly handle night shifts
    const sessions = await AttendanceSession.find({
      $or: [
        { inTime: { $gte: start, $lte: end } },
        { outTime: { $gte: start, $lte: end } }
      ]
    }).sort({ employeeId: 1, inTime: 1 });
    
    // Group sessions by employee
    const employeeSessions = {};
    sessions.forEach(session => {
      if (!employeeSessions[session.employeeId]) {
        employeeSessions[session.employeeId] = [];
      }
      employeeSessions[session.employeeId].push(session);
    });
    
    // Process each employee's sessions to identify daily attendance
    const dailyAttendance = [];
    
    for (const [employeeId, empSessions] of Object.entries(employeeSessions)) {
      // Get employee details
      const employee = await User.findOne({ empId: employeeId });
      
      // Define the target date range
      const targetDateStart = new Date(date);
      targetDateStart.setHours(0, 0, 0, 0);
      const targetDateEnd = new Date(date);
      targetDateEnd.setHours(23, 59, 59, 999);
      
      // Check if this employee has any night shift session that STARTS on the target date
      // We need to show these employees on the day they started their shift
      const sessionsStartingOnTargetDate = empSessions.filter(session => {
        if (!session.inTime) return false;
        const inTime = new Date(session.inTime);
        return inTime >= targetDateStart && inTime <= targetDateEnd;
      });
      
      // Check if this employee has any night shift session that ENDS on the target date
      // These employees should NOT appear on today's attendance (they appear on the IN date instead)
      const nightShiftSessionsEndingToday = empSessions.filter(session => {
        if (!session.inTime || !session.outTime) return false;
        
        const inTime = new Date(session.inTime);
        const outTime = new Date(session.outTime);
        
        // Check if IN and OUT are on different dates
        const inDate = inTime.toISOString().slice(0, 10);
        const outDate = outTime.toISOString().slice(0, 10);
        
        // Check if this is a night shift session that ends today
        return inDate !== outDate && outDate === targetDateStart.toISOString().slice(0, 10);
      });
      
      // If this employee has a night shift session ending today, skip them
      // They should only appear on the date their session started (IN date)
      if (nightShiftSessionsEndingToday.length > 0) {
        continue;
      }
      
      // If no sessions start on target date, skip this employee
      if (sessionsStartingOnTargetDate.length === 0) {
        continue;
      }
      
      // For night shift employees, we need to show both IN and OUT times
      // Get the first session that started on target date
      const targetSession = sessionsStartingOnTargetDate[0];
      
      let checkInTime = null;
      let checkOutTime = null;
      let isNightShift = false;
      let checkInFromPreviousDay = false;
      
      if (targetSession.inTime) {
        checkInTime = new Date(targetSession.inTime);
      }
      
      if (targetSession.outTime) {
        checkOutTime = new Date(targetSession.outTime);
        
        // Check if this is a night shift (IN and OUT on different dates)
        if (checkInTime) {
          const inDate = checkInTime.toISOString().slice(0, 10);
          const outDate = checkOutTime.toISOString().slice(0, 10);
          isNightShift = inDate !== outDate;
        }
      }
      
      // Format times for display
      let checkInDisplay = checkInTime ? checkInTime.toLocaleTimeString('en-IN', { 
        hour: '2-digit', 
        minute: '2-digit',
        hour12: true
      }) : '—';
      
      let checkOutDisplay = checkOutTime ? checkOutTime.toLocaleTimeString('en-IN', { 
        hour: '2-digit', 
        minute: '2-digit',
        hour12: true
      }) : '—';
      
      // Add night shift indicator
      if (isNightShift) {
        if (checkInTime) {
          checkInDisplay += ' (night shift)';
        }
        if (checkOutTime) {
          checkOutDisplay += ' (night shift)';
        }
      }
      
      // Determine status
      let status = 'Absent';
      if (checkInTime && checkOutTime) {
        status = 'Present';
      } else if (checkInTime) {
        status = 'IN Only';
      } else if (checkOutTime) {
        status = 'OUT Only';
      }
      
      // Find corresponding punch records to get image URLs
      let imageUrl = '';
      let inPunchId = null;
      let outPunchId = null;
      
      // Note: Since we've removed the Punch model, we'll return empty values for these fields
      // In a real implementation, you might store image URLs directly in the AttendanceSession model
      
      dailyAttendance.push({
        empId: employeeId, // Changed from employeeId to match frontend type
        name: employee ? `${employee.firstName} ${employee.lastName}` : employeeId,
        department: employee?.department || 'N/A',
        checkIn: checkInDisplay, // Use display format to match frontend expectations
        checkOut: checkOutDisplay, // Use display format to match frontend expectations
        checkInDisplay,
        checkOutDisplay,
        status,
        isNightShift,
        checkInFromPreviousDay, // Add this field
        imageUrl, // Add imageUrl to the response
        inPunchId, // Add inPunchId to the response
        outPunchId  // Add outPunchId to the response
      });
    }
    
    res.status(200).json({ data: dailyAttendance });
  } catch (err) {
    console.error("Error fetching daily attendance with night shift:", err);
    res.status(500).json({ error: "Server error" });
  }
};

// Helper: get all days in month (YYYY-MM)
function getAllDaysInMonth(year, month) {
  const date = new Date(Date.UTC(year, month - 1, 1));
  const days = [];
  while (date.getUTCMonth() === month - 1) {
    days.push(new Date(date));
    date.setUTCDate(date.getUTCDate() + 1);
  }
  return days;
}

// Helper: get previous month string (YYYY-MM)
function getPrevMonthStr(monthStr) {
  const [year, month] = monthStr.split("-").map(Number);
  const d = new Date(Date.UTC(year, month - 1, 1));
  d.setUTCMonth(d.getUTCMonth() - 1);
  return `${d.getUTCFullYear()}-${String(d.getUTCMonth() + 1).padStart(2, "0")}`;
}

// Monthly summary for a given month and department
export const getMonthlySummary = async (req, res) => {
  const { month, department = "All" } = req.query;
  if (!month || !/^\d{4}-\d{2}$/.test(month)) {
    return res.status(400).json({ error: "Month parameter (YYYY-MM) is required" });
  }
  try {
    const [year, monthNum] = month.split("-").map(Number);
    const start = new Date(Date.UTC(year, monthNum - 1, 1));
    const end = new Date(Date.UTC(year, monthNum, 0, 23, 59, 59, 999));
    
    // Get employees
    const userFilter = department === "All" ? {} : { department };
    const employees = await User.find({ ...userFilter, role: { $ne: 'ADMIN' } }).select("empId");
    const empIds = employees.map(e => e.empId);
    
    // Get all sessions for month
    const sessions = await AttendanceSession.find({
      employeeId: { $in: empIds },
      $or: [
        { inTime: { $gte: start, $lte: end } },
        { outTime: { $gte: start, $lte: end } }
      ]
    });
    
    // Working days (all days in month)
    const workingDays = getAllDaysInMonth(year, monthNum).length;
    
    // Calculate per-employee attendance data
    const now = new Date();
    const isCurrentMonth = (year === now.getFullYear() && monthNum === now.getMonth() + 1);
    const isFutureMonth = (year > now.getFullYear()) || (year === now.getFullYear() && monthNum > now.getMonth() + 1);
    const daysInMonth = getAllDaysInMonth(year, monthNum);
    
    // Pre-fetch all leave applications for employees for this month
    const Leave = (await import('../models/leave.model.js')).Leave;
    const leaveMap = {};
    for (const emp of employees) {
      // Get all approved leave applications for this employee in this month
      const leaves = await Leave.find({
        empId: emp.empId,
        year: year,
        'applications.status': 'Approved',
        $or: [
          { 'applications.startDate': { $lte: new Date(year, monthNum - 1, daysInMonth.length, 23, 59, 59, 999) } },
          { 'applications.endDate': { $gte: new Date(year, monthNum - 1, 1, 0, 0, 0, 0) } }
        ]
      });
      // Flatten all approved leave date ranges for this month
      const leaveDays = new Set();
      for (const leave of leaves) {
        for (const app of leave.applications) {
          if (app.status === 'Approved') {
            const appStart = new Date(app.startDate);
            const appEnd = new Date(app.endDate);
            for (let d = 0; d < daysInMonth.length; d++) {
              const day = new Date(daysInMonth[d]);
              if (day >= appStart && day <= appEnd) {
                leaveDays.add(daysInMonth[d].toISOString().slice(0, 10));
              }
            }
          }
        }
      }
      leaveMap[emp.empId] = leaveDays;
    }
    
    // Attendance map: empId -> { present: Set, late: count, inSessions: Set, outSessions: Set }
    const attendance = {};
    for (const emp of empIds) attendance[emp] = { present: new Set(), late: 0, inSessions: new Set(), outSessions: new Set() };
    for (const session of sessions) {
      const day = session.inTime.toISOString().slice(0, 10);
      attendance[session.employeeId].inSessions.add(day);
      attendance[session.employeeId].present.add(day);
      // Late if after 9:15 AM UTC
      const hour = session.inTime.getUTCHours();
      const min = session.inTime.getUTCMinutes();
      if (hour > 9 || (hour === 9 && min > 15)) attendance[session.employeeId].late++;
      
      if (session.outTime) {
        const outDay = session.outTime.toISOString().slice(0, 10);
        attendance[session.employeeId].outSessions.add(outDay);
      }
    }
    
    // Calculate statistics
    let totalOnTime = 0;    // Employees with full attendance (IN and OUT)
    let totalAbsent = 0;    // Employees with no sessions
    let totalOnLeave = 0;   // Employees with leave sessions
    let totalPartial = 0;   // Employees with only IN or only OUT
    let totalLate = 0;
    let totalWorkingDays = 0;
    let totalPresent = 0;
    
    for (const emp of employees) {
      const weeklyOff = emp.shiftDetails?.weeklyOff || null;
      let workingDaysForEmployee = 0;
      let presentForEmployee = 0;
      let absentForEmployee = 0;
      let partialForEmployee = 0;
      let leaveForEmployee = 0;
      let lateForEmployee = attendance[emp.empId].late;
      const leaveDays = leaveMap[emp.empId] || new Set();
      
      // Calculate working days for this employee
      for (let i = 0; i < daysInMonth.length; i++) {
        const day = new Date(daysInMonth[i]);
        const dayStr = daysInMonth[i].toISOString().slice(0, 10);
        
        // Skip future dates for current month
        if (isCurrentMonth && day > now) continue;
        if (isFutureMonth) continue;
        
        // Skip weekly off days
        if (weeklyOff && day.toLocaleString('en-US', { weekday: 'long' }) === weeklyOff) continue;
        
        // Check for leave days
        if (leaveDays.has(dayStr)) {
          leaveForEmployee++;
          continue;
        }
        
        workingDaysForEmployee++;
        
        // Check attendance status for this day
        const hasInSession = attendance[emp.empId].inSessions.has(dayStr);
        const hasOutSession = attendance[emp.empId].outSessions.has(dayStr);
        
        if (hasInSession && hasOutSession) {
          presentForEmployee++; // Full attendance
        } else if (hasInSession || hasOutSession) {
          partialForEmployee++; // Partial attendance
        } else {
          absentForEmployee++; // No sessions
        }
      }
      
      // Update totals based on employee's attendance pattern
      if (presentForEmployee > 0) totalOnTime += presentForEmployee;
      if (absentForEmployee > 0) totalAbsent += absentForEmployee;
      if (leaveForEmployee > 0) totalOnLeave += leaveForEmployee;
      if (partialForEmployee > 0) totalPartial += partialForEmployee;
      
      totalLate += lateForEmployee;
      totalWorkingDays += workingDaysForEmployee;
      totalPresent += presentForEmployee;
    }
    
    const avgAttendance = totalWorkingDays ? ((totalPresent / totalWorkingDays) * 100).toFixed(1) : 0;
    
    res.status(200).json({
      workingDays: Math.round(totalWorkingDays / employees.length), // Average working days per employee
      avgAttendance,
      totalAbsences: totalAbsent,
      lateArrivals: totalLate,
      onTime: totalOnTime,
      onLeave: totalOnLeave,
      partial: totalPartial, // Added partial attendance count
      totalEmployees: employees.length,
      month,
      department,
    });
  } catch (err) {
    console.error("[getMonthlySummary]", err);
    res.status(500).json({ error: "Failed to get monthly summary" });
  }
};

// 6-month attendance trend
export const getMonthlyTrend = async (req, res) => {
  try {
    const months = 6;
    const now = new Date();
    const trend = [];
    for (let i = months - 1; i >= 0; i--) {
      const d = new Date(Date.UTC(now.getUTCFullYear(), now.getUTCMonth() - i, 1));
      const year = d.getUTCFullYear();
      const monthNum = d.getUTCMonth() + 1;
      const start = new Date(Date.UTC(year, monthNum - 1, 1));
      const end = new Date(Date.UTC(year, monthNum, 0, 23, 59, 59, 999));
      // Use AttendanceSession instead of Punch
      const sessions = await AttendanceSession.find({ 
        inTime: { $gte: start, $lte: end } 
      });
      const workingDays = getAllDaysInMonth(year, monthNum).length;
      // Attendance map based on sessions
      const attendance = {};
      for (const session of sessions) {
        if (!attendance[session.employeeId]) attendance[session.employeeId] = { present: new Set(), late: 0 };
        const day = session.inTime.toISOString().slice(0, 10);
        attendance[session.employeeId].present.add(day);
        const hour = session.inTime.getUTCHours();
        const min = session.inTime.getUTCMinutes();
        if (hour > 9 || (hour === 9 && min > 15)) attendance[session.employeeId].late++;
      }
      let present = 0, late = 0;
      for (const emp in attendance) {
        present += attendance[emp].present.size;
        late += attendance[emp].late;
      }
      const total = workingDays * Object.keys(attendance).length;
      const absent = total - present;
      trend.push({
        month: d.toLocaleString('default', { month: 'short' }),
        present,
        absent,
        late,
        total: total,
      });
    }
    res.status(200).json({ trend });
  } catch (err) {
    console.error("[getMonthlyTrend]", err);
    res.status(500).json({ error: "Failed to get monthly trend" });
  }
};

// Per-employee monthly attendance
export const getEmployeeMonthlyAttendance = async (req, res) => {
  try {
    const { month = "2024-06", department = "All" } = req.query;
    console.log(`[getEmployeeMonthlyAttendance] Processing month: ${month}, department: ${department}`);
    const [year, monthNum] = month.split("-").map(Number);
    const start = new Date(Date.UTC(year, monthNum - 1, 1));
    const end = new Date(Date.UTC(year, monthNum, 0, 23, 59, 59, 999));
    const prevMonth = getPrevMonthStr(month);
    const [prevYear, prevMonthNum] = prevMonth.split("-").map(Number);
    const prevStart = new Date(Date.UTC(prevYear, prevMonthNum - 1, 1));
    const prevEnd = new Date(Date.UTC(prevYear, prevMonthNum, 0, 23, 59, 59, 999));
    // Get employees
    const userFilter = department === "All" ? {} : { department };
    const employees = await User.find({ ...userFilter, role: { $ne: 'ADMIN' } }).select("empId firstName lastName department");
    const empIds = employees.map(e => e.empId);
    // Get sessions for this and previous month instead of punches
    const sessions = await AttendanceSession.find({
      employeeId: { $in: empIds },
      inTime: { $gte: start, $lte: end },
    });
    const prevSessions = await AttendanceSession.find({
      employeeId: { $in: empIds },
      inTime: { $gte: prevStart, $lte: prevEnd },
    });
    // Attendance map: empId -> { present: Set, late: count }
    const attendance = {}, prevAttendance = {};
    for (const emp of empIds) {
      attendance[emp] = { present: new Set(), late: 0 };
      prevAttendance[emp] = { present: new Set(), late: 0 };
    }
    for (const session of sessions) {
      const day = session.inTime.toISOString().slice(0, 10);
      attendance[session.employeeId].present.add(day);
      const hour = session.inTime.getUTCHours();
      const min = session.inTime.getUTCMinutes();
      if (hour > 9 || (hour === 9 && min > 15)) attendance[session.employeeId].late++;
    }
    for (const session of prevSessions) {
      const day = session.inTime.toISOString().slice(0, 10);
      prevAttendance[session.employeeId].present.add(day);
      const hour = session.inTime.getUTCHours();
      const min = session.inTime.getUTCMinutes();
      if (hour > 9 || (hour === 9 && min > 15)) prevAttendance[session.employeeId].late++;
    }
    // Calculate working days (exclude future dates for current month, weekly offs, and approved leaves)
    const now = new Date();
    const isCurrentMonth = (year === now.getFullYear() && monthNum === now.getMonth() + 1);
    const isFutureMonth = (year > now.getFullYear()) || (year === now.getFullYear() && monthNum > now.getMonth() + 1);
    const daysInMonth = getAllDaysInMonth(year, monthNum);

    // Pre-fetch all leave applications for employees for this month
    const Leave = (await import('../models/leave.model.js')).Leave;
    const leaveMap = {};
    for (const emp of employees) {
      // Get all approved leave applications for this employee in this month
      const leaves = await Leave.find({
        empId: emp.empId,
        year: year,
        'applications.status': 'Approved',
        $or: [
          { 'applications.startDate': { $lte: new Date(year, monthNum - 1, daysInMonth.length, 23, 59, 59, 999) } },
          { 'applications.endDate': { $gte: new Date(year, monthNum - 1, 1, 0, 0, 0, 0) } }
        ]
      });
      // Flatten all approved leave date ranges for this month
      const leaveDays = new Set();
      for (const leave of leaves) {
        for (const app of leave.applications) {
          if (app.status === 'Approved') {
            const appStart = new Date(app.startDate);
            const appEnd = new Date(app.endDate);
            for (let d = 0; d < daysInMonth.length; d++) {
              const day = new Date(daysInMonth[d]);
              if (day >= appStart && day <= appEnd) {
                leaveDays.add(daysInMonth[d].toISOString().slice(0, 10));
              }
            }
          }
        }
      }
      leaveMap[emp.empId] = leaveDays;
    }

    const employeesData = employees.map(emp => {
      const weeklyOff = emp.shiftDetails?.weeklyOff || null;
      let workingDays = 0;
      let present = 0;
      let partial = 0; // Employees with only IN or only OUT sessions
      let late = attendance[emp.empId].late;
      const leaveDays = leaveMap[emp.empId] || new Set();
      
      console.log(`[getEmployeeMonthlyAttendance] Processing employee ${emp.empId}: weeklyOff=${weeklyOff}, leaveDays=${leaveDays.size}`);
      
      // Calculate working days for the month
      for (let i = 0; i < daysInMonth.length; i++) {
        const day = new Date(daysInMonth[i]);
        const dayStr = daysInMonth[i].toISOString().slice(0, 10);
        
        // Skip future dates for current month
        if (isCurrentMonth && day > now) continue;
        if (isFutureMonth) continue;
        
        // Skip weekly off days
        if (weeklyOff && day.toLocaleString('en-US', { weekday: 'long' }) === weeklyOff) continue;
        
        // Skip approved leave days
        if (leaveDays.has(dayStr)) continue;
        
        workingDays++;
        
        // Check if employee was present on this day
        if (attendance[emp.empId].present.has(dayStr)) {
          present++;
        }
        // Check for partial attendance (only IN session without OUT)
        else if (attendance[emp.empId].inSessions && attendance[emp.empId].inSessions.has(dayStr)) {
          partial++;
        }
      }
      
      const absent = workingDays - present - partial;
      const attendanceRate = workingDays > 0 ? ((present / workingDays) * 100).toFixed(1) : 0;
      
      // Trend: compare to previous month
      const prevPresent = prevAttendance[emp.empId].present.size;
      let trend = "up";
      if (present < prevPresent) trend = "down";
      else if (present === prevPresent) trend = "flat";
      
      console.log(`[getEmployeeMonthlyAttendance] Employee ${emp.empId} result: workingDays=${workingDays}, present=${present}, partial=${partial}, absent=${absent}, rate=${attendanceRate}%`);
      
      return {
        empId: emp.empId,
        name: `${emp.firstName} ${emp.lastName}`,
        department: emp.department,
        totalDays: workingDays,
        present,
        partial, // Added partial attendance count
        absent,
        late,
        attendanceRate,
        trend,
      };
    });
    res.status(200).json({ employees: employeesData });
  } catch (err) {
    console.error("[getEmployeeMonthlyAttendance]", err);
    res.status(500).json({ error: "Failed to get employee monthly attendance" });
  }
};

export const getAttendanceMonths = async (req, res) => {
  console.log("[getAttendanceMonths] Route hit");
  try {
    // Aggregate all unique months from AttendanceSession timestamps instead of Punch
    const months = await AttendanceSession.aggregate([
      {
        $group: {
          _id: { $dateToString: { format: "%Y-%m", date: "$inTime" } },
        },
      },
      { $sort: { "_id": -1 } },
    ]);
    // Format for dropdown: { month: 'YYYY-MM', label: 'MonthName YYYY' }
    const result = months.map(m => {
      const [year, month] = m._id.split("-");
      const date = new Date(Date.UTC(Number(year), Number(month) - 1, 1));
      const label = date.toLocaleString("default", { month: "long" }) + " " + year;
      return { month: m._id, label };
    });
    res.status(200).json({ months: result });
  } catch (err) {
    console.error("[getAttendanceMonths]", err);
    res.status(500).json({ error: "Failed to get attendance months" });
  }
};

export const getManualMonthlyAttendance = async (req, res) => {
  try {
    const { employeeId, year, month } = req.params;
    console.log(`[getManualMonthlyAttendance] Loading for employee: ${employeeId}, year: ${year}, month: ${month}`);
    const y = parseInt(year);
    const m = parseInt(month);
    const daysInMonth = new Date(y, m, 0).getDate();
    
    // For night shift detection, we need to look at sessions that might span into this month
    const start = new Date(Date.UTC(y, m - 1, 1, 0, 0, 0));
    // Extend the end date to include sessions that might end in the next month
    const end = new Date(Date.UTC(y, m, daysInMonth, 23, 59, 59, 999));
    
    console.log(`[getManualMonthlyAttendance] Date range: ${start.toISOString()} to ${end.toISOString()}`);
    
    // Fetch all sessions for this employee in the extended range
    const sessions = await AttendanceSession.find({
      employeeId,
      $or: [
        { inTime: { $gte: start, $lte: end } }, // Sessions that started in our range
        { outTime: { $gte: start, $lte: end } }, // Sessions that ended in our range
        { 
          inTime: { $lt: start }, // Sessions that started before our range
          outTime: { $gte: start, $lte: end } // But ended in our range (night shifts from previous day)
        },
        { status: 'OPEN' } // Open sessions
      ]
    });
    
    console.log(`[getManualMonthlyAttendance] Found ${sessions.length} sessions for employee ${employeeId}`);
    
    // Build daily attendance array
    const days = [];
    for (let d = 1; d <= daysInMonth; d++) {
      const date = new Date(Date.UTC(y, m - 1, d));
      const isoDate = date.toISOString().slice(0, 10);
      
      // Also check the next day for night shift OUT sessions
      const nextDate = new Date(date);
      nextDate.setUTCDate(nextDate.getUTCDate() + 1);
      const nextIsoDate = nextDate.toISOString().slice(0, 10);
      
      // Find sessions that started on this date
      const sessionsForDate = sessions.filter(s => {
        const inDate = new Date(s.inTime).toISOString().slice(0, 10);
        return inDate === isoDate;
      });
      
      // Also check for sessions that started on the previous day but ended on this date (night shifts)
      const prevDate = new Date(date);
      prevDate.setUTCDate(prevDate.getUTCDate() - 1);
      const prevIsoDate = prevDate.toISOString().slice(0, 10);
      
      const nightShiftSessions = sessions.filter(s => {
        const inDate = new Date(s.inTime).toISOString().slice(0, 10);
        const outDate = s.outTime ? new Date(s.outTime).toISOString().slice(0, 10) : null;
        // Sessions that started yesterday and ended today
        return inDate === prevIsoDate && outDate === isoDate;
      });
      
      let status = "Absent";
      let leaveType = null;
      let inTime = null;
      let outTime = null;
      let sessionId = null;
      let isNightShift = false;
      
      if (sessionsForDate.length > 0) {
        // Regular sessions that started today
        const session = sessionsForDate[0];
        status = session.outTime ? "Present" : "IN Only";
        
        // Convert UTC time to local time in HH:MM format
        const inLocal = new Date(session.inTime);
        inTime = `${inLocal.getHours().toString().padStart(2, '0')}:${inLocal.getMinutes().toString().padStart(2, '0')}`;
        
        if (session.outTime) {
          const outLocal = new Date(session.outTime);
          outTime = `${outLocal.getHours().toString().padStart(2, '0')}:${outLocal.getMinutes().toString().padStart(2, '0')}`;
          
          // Check if this session represents a night shift
          const outHour = outLocal.getUTCHours();
          const inHour = inLocal.getUTCHours();
          if (outHour >= 0 && outHour <= 8 && inHour >= 16 && inHour <= 23) {
            isNightShift = true;
            // If OUT is on next day, show it as "(to tomorrow)"
            const outDate = outLocal.toISOString().slice(0, 10);
            if (outDate === nextIsoDate) {
              // Removed the "(to tomorrow)" indicator as requested
            }
          }
        }
        
        sessionId = session.sessionId;
        console.log(`[getManualMonthlyAttendance] Found session for ${isoDate}: ${inTime} - ${outTime}`);
      } else if (nightShiftSessions.length > 0) {
        // Night shift sessions that started yesterday and ended today
        const session = nightShiftSessions[0];
        status = "Present";
        isNightShift = true;
        
        // For night shifts, we show the IN time from yesterday and OUT time from today
        const inLocal = new Date(session.inTime);
        inTime = `${inLocal.getHours().toString().padStart(2, '0')}:${inLocal.getMinutes().toString().padStart(2, '0')} (to yesterday)`;
        
        const outLocal = new Date(session.outTime);
        outTime = `${outLocal.getHours().toString().padStart(2, '0')}:${outLocal.getMinutes().toString().padStart(2, '0')}`;
        
        sessionId = session.sessionId;
        console.log(`[getManualMonthlyAttendance] Found night shift session for ${isoDate}: ${inTime} - ${outTime}`);
      }
      
      days.push({
        date: isoDate,
        status,
        inTime,
        outTime,
        sessionId, // Include session ID for manual OUT override
        leaveType,
        isNightShift, // Include night shift indicator
      });
    }
    
    console.log(`[getManualMonthlyAttendance] Returning ${days.length} days for employee ${employeeId}`);
    res.status(200).json({ days });
  } catch (err) {
    console.error("[getManualMonthlyAttendance]", err);
    res.status(500).json({ error: "Failed to fetch monthly attendance" });
  }
};

          // If OUT punch is on the next day and IN time is late evening, it's a night shift
          if ((outDate === nextIsoDate && inHour >= 16 && inHour <= 23) || 
              (outHour >= 0 && outHour <= 8 && inHour >= 16 && inHour <= 23)) {
            isNightShift = true;
            // If OUT is on next day, show it as "(to tomorrow)"
            if (outDate === nextIsoDate) {
              outTime += " (to tomorrow)";
            }
          }
        } else if (inPunch) {
          // For night shifts, look for a session that starts with this IN punch
          // Even if it's not matched by date, we need to find the corresponding session
          const matchingSession = sessions.find(s => 
            s.inTime.getTime() === inPunch.timestamp.getTime() && 
            s.employeeId === inPunch.employeeId
          );
          
          if (matchingSession) {
            status = matchingSession.outTime ? "Present" : "IN Only";
            sessionId = matchingSession.sessionId;
            
            // Convert UTC time to local time in HH:MM format
            const inLocal = new Date(matchingSession.inTime);
            inTime = `${inLocal.getHours().toString().padStart(2, '0')}:${inLocal.getMinutes().toString().padStart(2, '0')}`;
            
            if (matchingSession.outTime) {
              const outLocal = new Date(matchingSession.outTime);
              outTime = `${outLocal.getHours().toString().padStart(2, '0')}:${outLocal.getMinutes().toString().padStart(2, '0')}`;
              
              // Check if this session represents a night shift
              const outHour = outLocal.getUTCHours();
              const inHour = inLocal.getUTCHours();
              if (outHour >= 0 && outHour <= 8 && inHour >= 16 && inHour <= 23) {
                isNightShift = true;
                // If OUT is on next day, show it as "(to tomorrow)"
                const outDate = outLocal.toISOString().slice(0, 10);
                if (outDate === nextIsoDate) {
                  outTime += " (to tomorrow)";
                }
              }
            }
            
            console.log(`[getManualMonthlyAttendance] Found session for ${isoDate}: ${inTime} - ${outTime}`);
          } else {
            // Orphaned IN punch without session
            status = "IN Only";
            const inLocal = new Date(inPunch.timestamp);
            inTime = `${inLocal.getHours().toString().padStart(2, '0')}:${inLocal.getMinutes().toString().padStart(2, '0')}`;
            
            // Check if this is a night shift (IN time is late evening)
            const inHour = inLocal.getUTCHours();
            if (inHour >= 16 && inHour <= 23) {
              isNightShift = true;
            }
          }
        } else {
          // Check for OUT-only punches
          const outPunch = punches.find(p => {
            const punchDate = new Date(p.timestamp);
            const punchIsoDate = punchDate.toISOString().slice(0, 10);
            return p.punchType === "OUT" && punchIsoDate === isoDate;
          });
          
          if (outPunch) {
            status = "OUT Only";
            const outLocal = new Date(outPunch.timestamp);
            outTime = `${outLocal.getHours().toString().padStart(2, '0')}:${outLocal.getMinutes().toString().padStart(2, '0')}`;
            
            // Check if this is a night shift (OUT time is early morning)
            const outHour = outLocal.getUTCHours();
            if (outHour >= 0 && outHour <= 8) {
              isNightShift = true;
            }
          } else {
            console.log(`[getManualMonthlyAttendance] No punches found for ${isoDate}, marking as Absent`);
          }
        }
      }
      
      days.push({
        date: isoDate,
        status,
        inTime,
        outTime,
        sessionId, // Include session ID for manual OUT override
        leaveType,
        isNightShift, // Include night shift indicator
      });
    }
    
    console.log(`[getManualMonthlyAttendance] Returning ${days.length} days for employee ${employeeId}`);
    res.status(200).json({ days });
  } catch (err) {
    console.error("[getManualMonthlyAttendance]", err);
    res.status(500).json({ error: "Failed to fetch monthly attendance" });
  }
};

export const updateManualMonthlyAttendance = async (req, res) => {
  try {
    const { employeeId, year, month } = req.params;
    const { days } = req.body; // Array of { date, status, inTime, outTime, leaveType, isNightShift }
    console.log(`[updateManualMonthlyAttendance] Saving for employee: ${employeeId}, year: ${year}, month: ${month}`);
    console.log(`[updateManualMonthlyAttendance] Days to save:`, days.map(d => ({ date: d.date, status: d.status, leaveType: d.leaveType, isNightShift: d.isNightShift })));
    if (!Array.isArray(days)) {
      return res.status(400).json({ error: "Invalid days array" });
    }
    
    // Only process days that have meaningful changes
    const daysToProcess = days.filter(day => {
      const { status, inTime, outTime, leaveType } = day;
      // Process if: Present with both times, Leave with leaveType, or explicitly marked Absent
      return (status === "Present" && inTime && outTime) || 
             (status === "Leave" && leaveType) || 
             (status === "Absent"); // Process all Absent days to delete sessions
    });
    
    console.log(`[updateManualMonthlyAttendance] Processing ${daysToProcess.length} days with meaningful changes`);
    
    for (const day of daysToProcess) {
      const { date, status, inTime, outTime, leaveType, isNightShift } = day;
      // Use proper date parsing to avoid timezone issues
      const [yearStr, monthStr, dayStr] = date.split('-');
      const dayStart = new Date(Date.UTC(parseInt(yearStr), parseInt(monthStr) - 1, parseInt(dayStr), 0, 0, 0, 0));
      const dayEnd = new Date(Date.UTC(parseInt(yearStr), parseInt(monthStr) - 1, parseInt(dayStr), 23, 59, 59, 999));
      
      console.log(`[updateManualMonthlyAttendance] Processing date ${date} with range: ${dayStart.toISOString()} to ${dayEnd.toISOString()}`);
      
      // Remove existing sessions for this day
      const deleteResult = await AttendanceSession.deleteMany({
        employeeId,
        inTime: { $gte: dayStart, $lte: dayEnd },
      });
      
      console.log(`[updateManualMonthlyAttendance] Deleted ${deleteResult.deletedCount} sessions for ${date}`);
      
      if (status === "Present" && inTime && outTime) {
        // Parse the timestamps correctly as local time instead of UTC
        let inTimestamp, outTimestamp;
        
        if (inTime.includes('T')) {
          inTimestamp = new Date(inTime);
        } else {
          // Parse time as local time, not UTC
          const [inHour, inMinute] = inTime.split(':').map(Number);
          inTimestamp = new Date(date);
          inTimestamp.setHours(inHour, inMinute, 0, 0);
        }
        
        if (outTime.includes('T')) {
          outTimestamp = new Date(outTime);
        } else {
          // Parse time as local time, not UTC
          const [outHour, outMinute] = outTime.split(':').map(Number);
          outTimestamp = new Date(date);
          outTimestamp.setHours(outHour, outMinute, 0, 0);
          
          // Handle night shift scenario where OUT time is early morning (0-8 AM)
          // and IN time is late evening (16-23 PM) - OUT should be on next day
          const inHour = inTimestamp.getHours();
          if (outHour >= 0 && outHour <= 8 && inHour >= 16) {
            // Move OUT time to next day
            outTimestamp.setDate(outTimestamp.getDate() + 1);
          }
        }
        
        // Handle reverse order session detection for night shifts
        // If OUT session is in early morning (0-8 AM) and comes before IN session,
        // shift it to the next date
        const outHour = outTimestamp.getHours();
        if (outHour >= 0 && outHour <= 8 && outTimestamp < inTimestamp) {
          // Shift the OUT session to the next date
          const shiftedOutTime = new Date(outTimestamp);
          shiftedOutTime.setDate(shiftedOutTime.getDate() + 1);
          outTimestamp = shiftedOutTime;
          console.log(`[updateManualMonthlyAttendance] Shifting OUT session from ${outTimestamp.toISOString()} to ${shiftedOutTime.toISOString()} for reverse order handling`);
        }
        
        // Create session for this day
        const session = await AttendanceSession.create({
          sessionId: 0, // Temporary value, will be updated by pre-save hook
          employeeId,
          inTime: inTimestamp,
          outTime: outTimestamp,
          status: 'CLOSED' // Manual entries are always closed sessions
        });
        
        console.log(`[updateManualMonthlyAttendance] Saved Present for ${date} with session ID ${session.sessionId}`);
      } else if (status === "Leave" && leaveType) {
        // Add LEAVE session
        const leaveTimestamp = new Date(date + "T09:00:00.000Z");
        console.log(`[updateManualMonthlyAttendance] Creating LEAVE session for ${date}: ${leaveType} at ${leaveTimestamp.toISOString()}`);
        await AttendanceSession.create({
          sessionId: 0, // Temporary value, will be updated by pre-save hook
          employeeId,
          inTime: leaveTimestamp,
          status: 'LEAVE'
        });
        console.log(`[updateManualMonthlyAttendance] Saved Leave for ${date}: ${leaveType}`);
      } else if (status === "Absent") {
        // For Absent status, we've already deleted existing sessions above
        console.log(`[updateManualMonthlyAttendance] Marked Absent for ${date} - ${deleteResult.deletedCount} sessions deleted`);
      }
      // If Absent, do nothing (no session)
    }
    
    // After saving, fetch the updated attendance data to return the correct status including night shift info
    const y = parseInt(year);
    const m = parseInt(month);
    const daysInMonth = new Date(y, m, 0).getDate();
    const start = new Date(Date.UTC(y, m - 1, 1, 0, 0, 0));
    const end = new Date(Date.UTC(y, m - 1, daysInMonth, 23, 59, 59, 999));
    
    // Fetch all sessions for this employee in the month
    const sessions = await AttendanceSession.find({
      employeeId,
      $or: [
        { inTime: { $gte: start, $lte: end } },
        { outTime: { $gte: start, $lte: end } },
        { status: 'OPEN' }
      ]
    });
    
    console.log(`[updateManualMonthlyAttendance] Found ${sessions.length} sessions after processing`);
    
    // Build daily attendance array with updated information
    const updatedDays = [];
    for (let d = 1; d <= daysInMonth; d++) {
      const date = new Date(Date.UTC(y, m - 1, d));
      const isoDate = date.toISOString().slice(0, 10);
      
      // Find session for this day
      const session = sessions.find(s => {
        const inDate = new Date(s.inTime).toISOString().slice(0, 10);
        return inDate === isoDate;
      });
      
      let status = "Absent";
      let leaveType = null;
      let inTime = null;
      let outTime = null;
      let sessionId = null;
      let isNightShift = false;
      
      if (session) {
        if (session.status === 'LEAVE') {
          status = "Leave";
          leaveType = "Manual Leave";
        } else {
          status = session.outTime ? "Present" : "IN Only";
          
          // Convert UTC time to local time in HH:MM format
          const inLocal = new Date(session.inTime);
          inTime = `${inLocal.getHours().toString().padStart(2, '0')}:${inLocal.getMinutes().toString().padStart(2, '0')}`;
          
          if (session.outTime) {
            const outLocal = new Date(session.outTime);
            outTime = `${outLocal.getHours().toString().padStart(2, '0')}:${outLocal.getMinutes().toString().padStart(2, '0')}`;
            
            // Check if this session represents a night shift
            const outHour = outLocal.getUTCHours();
            const inHour = new Date(session.inTime).getUTCHours();
            if (outHour >= 0 && outHour <= 8 && inHour >= 16 && inHour <= 23) {
              isNightShift = true;
            }
          }
          
          sessionId = session.sessionId;
        }
      }
      
      updatedDays.push({
        date: isoDate,
        status,
        inTime,
        outTime,
        sessionId, // Include session ID for manual OUT override
        leaveType,
        isNightShift, // Include night shift indicator
        isNightShiftSelected: isNightShift // Include night shift selection for frontend
      });
    }
    
    console.log(`[updateManualMonthlyAttendance] Successfully saved all days for employee ${employeeId}`);
    res.status(200).json({ success: true, days: updatedDays });
  } catch (err) {
    console.error("[updateManualMonthlyAttendance]", err);
    res.status(500).json({ error: "Failed to update monthly attendance" });
  }
};

      let inTime = null;
      let outTime = null;
      let sessionId = null;
      let isNightShift = false;
      
      // --- PRIORITIZE LEAVE punch ---
      if (leavePunch) {
        status = "Leave";
        leaveType = leavePunch.reason || null;
      } else if (inPunch && (outPunch || session)) {
        status = "Present";


        // Convert UTC time to local time in HH:MM format
        const inLocal = new Date(inPunch.timestamp);
        inTime = `${inLocal.getHours().toString().padStart(2, '0')}:${inLocal.getMinutes().toString().padStart(2, '0')}`;
        
        // Use out punch if available, otherwise use session out time
        if (outPunch) {
          const outLocal = new Date(outPunch.timestamp);
          outTime = `${outLocal.getHours().toString().padStart(2, '0')}:${outLocal.getMinutes().toString().padStart(2, '0')}`;
          
          // Handle night shift scenario: if OUT time is early morning (0-8) and IN time is late evening (16-23)
          // then this is a night shift
          const outHour = outLocal.getUTCHours();
          const inHour = inLocal.getUTCHours();
          if (outHour >= 0 && outHour <= 8 && inHour >= 16 && inHour <= 23) {
            isNightShift = true;
          }
        } else if (session && session.outTime) {
          const outLocal = new Date(session.outTime);
          outTime = `${outLocal.getHours().toString().padStart(2, '0')}:${outLocal.getMinutes().toString().padStart(2, '0')}`;
          
          // Check if this session represents a night shift
          const outHour = outLocal.getUTCHours();
          const inHour = new Date(session.inTime).getUTCHours();
          if (outHour >= 0 && outHour <= 8 && inHour >= 16 && inHour <= 23) {
            isNightShift = true;
          }
        }
        
        // Set session ID if available
        if (session) {
          sessionId = session.sessionId;
        }
      } else if (inPunch) {
        status = "IN Only";
        // Convert UTC time to local time in HH:MM format
        const inLocal = new Date(inPunch.timestamp);
        inTime = `${inLocal.getHours().toString().padStart(2, '0')}:${inLocal.getMinutes().toString().padStart(2, '0')}`;
        
        // Check if this is a night shift (IN time is late evening)
        const inHour = inLocal.getUTCHours();
        if (inHour >= 16 && inHour <= 23) {
          isNightShift = true;
        }
        
        // Set session ID if available
        if (session) {
          sessionId = session.sessionId;
        }
      } else if (outPunch) {
        status = "OUT Only";
        // Convert UTC time to local time in HH:MM format
        const outLocal = new Date(outPunch.timestamp);
        outTime = `${outLocal.getHours().toString().padStart(2, '0')}:${outLocal.getMinutes().toString().padStart(2, '0')}`;
        
        // Check if this is a night shift (OUT time is early morning)
        const outHour = outLocal.getUTCHours();
        if (outHour >= 0 && outHour <= 8) {
          isNightShift = true;
        }
      }
      
      updatedDays.push({
        date: isoDate,
        status,
        inTime,
        outTime,
        sessionId, // Include session ID for manual OUT override
        leaveType,
        isNightShift, // Include night shift indicator
        isNightShiftSelected: isNightShift // Include night shift selection for frontend
      });
    }
    
    console.log(`[updateManualMonthlyAttendance] Successfully saved all days for employee ${employeeId}`);
    res.status(200).json({ success: true, days: updatedDays });
  } catch (err) {
    console.error("[updateManualMonthlyAttendance]", err);
    res.status(500).json({ error: "Failed to update monthly attendance" });
  }
};

export const cleanupDuplicatePunches = async (req, res) => {
  try {
    const { employeeId, startDate, endDate } = req.body;
    
    if (!employeeId || !startDate || !endDate) {
      return res.status(400).json({ error: "Employee ID, start date, and end date are required" });
    }
    
    const start = new Date(startDate);
    const end = new Date(endDate);
    
    // Find all sessions for the employee in the date range
    const sessions = await AttendanceSession.find({
      employeeId,
      inTime: { $gte: start, $lte: end }
    }).sort({ inTime: 1 });
    
    console.log(`[cleanupDuplicatePunches] Found ${sessions.length} sessions for employee ${employeeId}`);
    
    // Group by date
    const sessionGroups = {};
    for (const session of sessions) {
      const dateStr = session.inTime.toISOString().slice(0, 10);
      if (!sessionGroups[dateStr]) {
        sessionGroups[dateStr] = [];
      }
      sessionGroups[dateStr].push(session);
    }
    
    // Remove duplicates, keeping the highest priority one
    let deletedCount = 0;
    for (const [key, sessionList] of Object.entries(sessionGroups)) {
      if (sessionList.length > 1) {
        // Sort by priority: LEAVE > Manual Entry > Auto Session
        const priority = {
          'LEAVE': 3,
          'Manual Entry by HR': 2,
          'Auto Session': 1
        };
        
        sessionList.sort((a, b) => {
          const aPriority = priority[a.reason] || 0;
          const bPriority = priority[b.reason] || 0;
          return bPriority - aPriority; // Higher priority first
        });
        
        // Keep the first one (highest priority), delete the rest
        const toDelete = sessionList.slice(1);
        for (const session of toDelete) {
          await AttendanceSession.findByIdAndDelete(session._id);
          deletedCount++;
        }
        
        console.log(`[cleanupDuplicatePunches] Deleted ${toDelete.length} duplicate sessions for ${key}`);
      }
    }
    
    res.status(200).json({ 
      success: true, 
      message: `Cleaned up ${deletedCount} duplicate session records`,
      deletedCount 
    });
    
  } catch (err) {
    console.error("[cleanupDuplicatePunches]", err);
    res.status(500).json({ error: "Failed to cleanup duplicate sessions" });
  }
};

// POST /api/v1/punch/contractor
export const recordContractorPunch = async (req, res) => {
  try {
    const { contractorId, punchType, base64Image } = req.body;
    if (!contractorId || !punchType || !base64Image) {
      return res.status(400).json({ error: 'Missing fields' });
    }
    // Validate contractor
    const contractor = await Contractor.findById(contractorId);
    if (!contractor) {
      return res.status(404).json({ error: 'Contractor not found' });
    }
    // Date boundaries for today
    const startOfDay = new Date();
    startOfDay.setHours(0, 0, 0, 0);
    const endOfDay = new Date();
    endOfDay.setHours(23, 59, 59, 999);
    // Prevent duplicate punch of same type for today
    if (["IN", "OUT"].includes(punchType.toUpperCase())) {
      const existing = await ContractorPunch.findOne({
        contractorId,
        punchType: punchType.toUpperCase(),
        timestamp: { $gte: startOfDay, $lte: endOfDay },
      });
      if (existing) {
        return res.status(409).json({ error: `Punch of type '${punchType}' already exists for today.` });
      }
    }
    // Save image
    const __dirname = path.dirname(fileURLToPath(import.meta.url));
    const uploadDir = path.join(__dirname, '..', 'uploads');
    if (!fs.existsSync(uploadDir)) {
      fs.mkdirSync(uploadDir, { recursive: true });
    }
    const fileName = `contractor_${contractorId}_${Date.now()}.jpg`;
    const imagePath = path.join(uploadDir, fileName);
    const base64Data = base64Image.replace(/^data:image\/\w+;base64,/, '');
    const imageBuffer = Buffer.from(base64Data, 'base64');
    fs.writeFileSync(imagePath, imageBuffer);
    // Upload to Cloudinary
    const publicId = `contractor-punches/${contractorId}/${punchType}_${Date.now()}`;
    const uploadResult = await uploadPunchImageToCloudinary(imagePath, publicId);
    // Create punch
    const punch = await ContractorPunch.create({
      contractorId,
      punchType: punchType.toUpperCase(),
      imageUrl: uploadResult.secure_url,
    });
    res.status(201).json({ message: 'Punch recorded', punch });
  } catch (err) {
    console.error('Contractor Punch Error:', err);
    res.status(500).json({ error: 'Server error' });
  }
};

// GET /api/v1/punch/contractor/counts?contractorId=...
export const getContractorPunchCounts = async (req, res) => {
  try {
    const { contractorId, date, month } = req.query;
    if (!contractorId) return res.status(400).json({ error: 'Missing contractorId' });
    // Day count
    let todayCount = 0;
    if (date) {
      const start = new Date(date + 'T00:00:00.000Z');
      const end = new Date(date + 'T23:59:59.999Z');
      todayCount = await ContractorPunch.countDocuments({
        contractorId,
        timestamp: { $gte: start, $lte: end },
      });
    } else {
      // Default: today
      const today = new Date();
      today.setHours(0, 0, 0, 0);
      const tomorrow = new Date(today);
      tomorrow.setDate(today.getDate() + 1);
      todayCount = await ContractorPunch.countDocuments({
        contractorId,
        timestamp: { $gte: today, $lt: tomorrow },
      });
    }
    // Month count
    let monthCount = 0;
    if (month) {
      const [year, monthNum] = month.split('-').map(Number);
      const monthStart = new Date(Date.UTC(year, monthNum - 1, 1));
      const monthEnd = new Date(Date.UTC(year, monthNum, 1));
      monthCount = await ContractorPunch.countDocuments({
        contractorId,
        timestamp: { $gte: monthStart, $lt: monthEnd },
      });
    } else {
      // Default: this month
      const today = new Date();
      const year = today.getFullYear();
      const monthNum = today.getMonth();
      const monthStart = new Date(year, monthNum, 1);
      const monthEnd = new Date(year, monthNum + 1, 1);
      monthCount = await ContractorPunch.countDocuments({
        contractorId,
        timestamp: { $gte: monthStart, $lt: monthEnd },
      });
    }
    res.json({ todayCount, monthCount });
  } catch (err) {
    console.error('Contractor Punch Counts Error:', err);
    res.status(500).json({ error: 'Server error' });
  }
};

// Get recent manual punches for a given date
export const getRecentManualPunchesByDate = async (req, res) => {
  try {
    const { date } = req.query;
    if (!date) return res.status(400).json({ error: "Missing date query param (YYYY-MM-DD)" });
    const start = new Date(date + 'T00:00:00.000Z');
    const end = new Date(date + 'T23:59:59.999Z');
    // Manual sessions: those with a non-empty reason
    const sessions = await AttendanceSession.find({
      inTime: { $gte: start, $lte: end },
      reason: { $exists: true, $ne: null, $ne: "" }
    }).sort({ inTime: -1 });
    res.status(200).json({ data: sessions });
  } catch (err) {
    console.error("Error fetching recent manual sessions by date:", err);
    res.status(500).json({ error: "Server error" });
  }
};

export const getTodaysPunchDetails = async (_, res) => {
  try {
    const today = new Date();
    today.setHours(0, 0, 0, 0);
    const tomorrow = new Date(today);
    tomorrow.setDate(today.getDate() + 1);

    const employees = await User.find({ role: { $ne: 'ADMIN' } });
    const results = [];

    for (const emp of employees) {
      // Find today's sessions for this employee
      const sessions = await AttendanceSession.find({
        employeeId: emp.empId,
        inTime: { $gte: today, $lt: tomorrow }
      });

      // Process sessions to get IN/OUT times
      let inTime = null, outTime = null, inPhoto = null, outPhoto = null, workedHours = null;
      
      // Get the first session for IN time (there should typically be only one)
      if (sessions.length > 0) {
        const session = sessions[0];
        const inDate = new Date(session.inTime);
        inTime = `${inDate.getHours().toString().padStart(2, '0')}:${inDate.getMinutes().toString().padStart(2, '0')}`;
        // For photos, we'll use placeholder since we're not tracking them in sessions
        inPhoto = '/placeholder-punch.jpg';
        
        // If session is closed, get OUT time
        if (session.outTime) {
          const outDate = new Date(session.outTime);
          outTime = `${outDate.getHours().toString().padStart(2, '0')}:${outDate.getMinutes().toString().padStart(2, '0')}`;
          outPhoto = '/placeholder-punch.jpg';
          
          // Calculate worked hours
          const ms = new Date(session.outTime) - new Date(session.inTime);
          const hours = Math.floor(ms / (1000 * 60 * 60));
          const mins = Math.floor((ms / (1000 * 60)) % 60);
          workedHours = `${hours}:${mins.toString().padStart(2, '0')}`;
        }
      }

      results.push({
        employeeId: emp.empId,
        name: emp.firstName ? `${emp.firstName} ${emp.lastName}` : emp.name,
        inTime,
        inPhoto,
        outTime,
        outPhoto,
        workedHours
      });
    }
    res.json({ data: results });
  } catch (err) {
    console.error('Todays Punch Details Error:', err);
    res.status(500).json({ error: 'Server error' });
  }
};

// GET /api/v1/punch/contractor/employees?contractorId=...
export const getContractorEmployees = async (req, res) => {
  try {
    const { contractorId } = req.query;
    if (!contractorId) return res.status(400).json({ error: 'Missing contractorId' });

    const Contractor = (await import('../models/contractor.model.js')).default;
    const contractor = await Contractor.findById(contractorId);
    if (!contractor) return res.status(404).json({ error: 'Contractor not found' });

    // Return contractor employees with their IDs
    const employees = contractor.contractorIds.map((empId, index) => ({
      contractorEmployeeId: empId,
      employeeName: `${contractor.name} - Employee ${index + 1}`,
      contractorId: contractor._id,
      contractorName: contractor.name
    }));

    res.json(employees);
  } catch (err) {
    console.error('Get Contractor Employees Error:', err);
    res.status(500).json({ error: 'Server error' });
  }
};

// GET /api/v1/punch/contractor/detailed?contractorId=...&contractorEmployeeId=...&date=YYYY-MM-DD&month=YYYY-MM
export const getContractorDetailedPunches = async (req, res) => {
  try {
    const { contractorId, contractorEmployeeId, date, month } = req.query;
    if (!contractorId) return res.status(400).json({ error: 'Missing contractorId' });

    let query = { contractorId };
    
    // If specific employee ID is provided, filter by it
    if (contractorEmployeeId) {
      query.contractorEmployeeId = contractorEmployeeId;
    }
    
    if (date) {
      // Get punches for specific date
      const targetDate = new Date(date);
      targetDate.setHours(0, 0, 0, 0);
      const endDate = new Date(targetDate);
      endDate.setHours(23, 59, 59, 999);
      query.timestamp = { $gte: targetDate, $lte: endDate };
    } else if (month) {
      // Get punches for specific month
      const [year, monthNum] = month.split('-');
      const startDate = new Date(parseInt(year), parseInt(monthNum) - 1, 1);
      const endDate = new Date(parseInt(year), parseInt(monthNum), 0, 23, 59, 59, 999);
      query.timestamp = { $gte: startDate, $lte: endDate };
    }

    const punches = await ContractorPunch.find(query)
      .sort({ contractorEmployeeId: 1, timestamp: 1 })
      .lean();

    // Group punches by employee if no specific employee requested
    if (!contractorEmployeeId) {
      const groupedPunches = {};
      punches.forEach(punch => {
        if (!groupedPunches[punch.contractorEmployeeId]) {
          groupedPunches[punch.contractorEmployeeId] = [];
        }
        groupedPunches[punch.contractorEmployeeId].push(punch);
      });
      res.json(groupedPunches);
    } else {
      res.json(punches);
    }
  } catch (err) {
    console.error('Contractor Detailed Punches Error:', err);
    res.status(500).json({ error: 'Server error' });
  }
};

// POST /api/v1/punch/contractor/manual - Manual contractor employee punch entry by HR
export const manualContractorPunchByHR = async (req, res) => {
  try {
    const { contractorId, contractorEmployeeId, employeeName, punchType, reason, timestamp } = req.body;

    // Validate required fields
    if (!contractorId || !contractorEmployeeId || !punchType || !timestamp) {
      return res.status(400).json({ error: 'Missing required fields: contractorId, contractorEmployeeId, punchType, timestamp' });
    }

    // Validate punch type
    if (!['IN', 'OUT'].includes(punchType.toUpperCase())) {
      return res.status(400).json({ error: 'Invalid punch type. Must be IN or OUT' });
    }

    // Validate contractor exists
    const Contractor = (await import('../models/contractor.model.js')).default;
    const contractor = await Contractor.findById(contractorId);
    if (!contractor) {
      return res.status(404).json({ error: 'Contractor not found' });
    }

    // Validate contractor employee ID exists in contractor's employee list
    if (!contractor.contractorIds.includes(contractorEmployeeId)) {
      return res.status(400).json({ error: 'Invalid contractor employee ID' });
    }

    // Parse timestamp
    const punchTime = new Date(timestamp);
    if (isNaN(punchTime.getTime())) {
      return res.status(400).json({ error: 'Invalid timestamp format' });
    }

    // Check if punch is in the future
    if (punchTime > new Date()) {
      return res.status(400).json({ error: 'Cannot create punch entries for future dates' });
    }

    // Handle reverse order punch detection for night shifts (for OUT punches)
    let finalPunchTime = punchTime;
    if (punchType.toUpperCase() === "OUT") {
      const punchHour = punchTime.getHours();
      
      // If OUT punch is in early morning (0-8 AM), 
      // we might need to shift it to the next date for proper payroll calculation
      if (punchHour >= 0 && punchHour <= 8) {
        // For contractor punches, we'll add a note about the potential shift
        // but not automatically shift since we don't have the full context
        console.log(`[manualContractorPunchByHR] OUT punch in early morning (${punchTime.toISOString()}). Consider if this should be shifted to next day for payroll.`);
      }
    }
    
    // Handle reverse order punch detection for night shifts (for IN punches)
    if (punchType.toUpperCase() === "IN") {
      const punchHour = punchTime.getHours();
      
      // If IN punch is in late night (16-23 PM), 
      // this might be part of a night shift that started the previous day
      if (punchHour >= 16 && punchHour <= 23) {
        console.log(`[manualContractorPunchByHR] IN punch in late night (${punchTime.toISOString()}). This might be part of a night shift.`);
      }
    }

    // Create the manual contractor employee punch
    const newPunch = await ContractorPunch.create({
      contractorId,
      contractorEmployeeId,
      employeeName: employeeName || `${contractor.name} - Employee`,
      punchType: punchType.toUpperCase(),
      imageUrl: '/placeholder-manual-punch.jpg', // Placeholder for manual entries
      timestamp: finalPunchTime,
      enteredBy: `Manual Entry by HR - ${req.user?.empId || 'HR'}`,
      reason: reason || 'Manual Entry by HR'
    });

    console.log(`Manual contractor employee punch created: ${employeeName || contractorEmployeeId} - ${punchType} at ${finalPunchTime.toISOString()}`);

    return res.status(201).json({ 
      message: "Manual contractor employee punch added successfully", 
      punch: newPunch 
    });

  } catch (err) {
    console.error("Error in manualContractorPunchByHR:", err);
    return res.status(500).json({ error: "Server error" });
  }
};


