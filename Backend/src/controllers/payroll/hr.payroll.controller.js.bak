// Get monthly attendance summary (moved from hr.controller.js)
export const getMonthlyAttendanceSummary = async (req, res, isInternalCall = false) => {
  try {
    console.log('[getMonthlyAttendanceSummary] Starting function, isInternalCall:', isInternalCall);
    const { month, phDates = [] } = req.query; // phDates: array of YYYY-MM-DD
    console.log('[getMonthlyAttendanceSummary] Received params:', { month, phDates });
    if (!month) {
      console.log('[getMonthlyAttendanceSummary] Missing month parameter');
      if (isInternalCall) {
        throw new Error("Month is required (YYYY-MM)");
      }
      // Check if res has status method before calling it
      if (res && typeof res.status === 'function') {
        return res.status(400).json({ error: "Month is required (YYYY-MM)" });
      } else {
        throw new Error("Month is required (YYYY-MM)");
      }
    }

    const [year, monthNum] = month.split("-").map(Number);
    console.log('[getMonthlyAttendanceSummary] Parsed date:', { year, monthNum });
    const startDate = new Date(year, monthNum - 1, 1);
    const endDate = new Date(year, monthNum, 0, 23, 59, 59, 999);
    const daysInMonth = new Date(year, monthNum, 0).getDate();
    console.log('[getMonthlyAttendanceSummary] Date range:', { startDate, endDate, daysInMonth });

    // Get all employees
    console.log('[getMonthlyAttendanceSummary] Fetching employees');
    const employees = await User.find({ role: { $ne: 'ADMIN' } });
    console.log('[getMonthlyAttendanceSummary] Found employees:', employees.length);

    // Pre-fetch all approved leaves for employees for this month
    console.log('[getMonthlyAttendanceSummary] Importing Leave model');
    let Leave;
    try {
      const leaveModule = await import('../../models/leave.model.js');
      Leave = leaveModule.Leave;
      console.log('[getMonthlyAttendanceSummary] Leave model imported successfully');
    } catch (importError) {
      console.error('[getMonthlyAttendanceSummary] Error importing Leave model:', importError);
      if (isInternalCall) {
        throw new Error("Failed to import Leave model");
      }
      // Check if res has status method before calling it
      if (res && typeof res.status === 'function') {
        return res.status(500).json({ error: "Server error", message: "Failed to import Leave model" });
      } else {
        throw new Error("Failed to import Leave model");
      }
    }

    const leaveMap = {};
    console.log('[getMonthlyAttendanceSummary] Processing leaves for employees');
    for (const emp of employees) {
      try {
        const leaves = await Leave.find({
          empId: emp.empId,
          year: year,
          'applications.status': 'Approved',
          $or: [
            { 'applications.startDate': { $lte: new Date(year, monthNum - 1, daysInMonth, 23, 59, 59, 999) } },
            { 'applications.endDate': { $gte: new Date(year, monthNum - 1, 1, 0, 0, 0, 0) } }
          ]
        });
        // Flatten all approved leave date ranges for this month
        const leaveDays = {};
        for (const leave of leaves) {
          for (const app of leave.applications) {
            if (app.status === 'Approved') {
              const appStart = new Date(app.startDate);
              const appEnd = new Date(app.endDate);
              for (let d = 1; d <= daysInMonth; d++) {
                const day = new Date(year, monthNum - 1, d);
                if (day >= appStart && day <= appEnd) {
                  leaveDays[d] = leave.leaveType;
                }
              }
            }
          }
        }
        leaveMap[emp.empId] = leaveDays;
      } catch (leaveError) {
        console.error(`[getMonthlyAttendanceSummary] Error processing leaves for employee ${emp.empId}:`, leaveError);
      }
    }
    console.log('[getMonthlyAttendanceSummary] Leave map created');

    // Get all sessions for attendance calculation
    // Include sessions that started in this month or previous month but ended in this month (for night shifts)
    console.log('[getMonthlyAttendanceSummary] Fetching attendance sessions');
    const allSessions = await AttendanceSession.find({
      employeeId: { $in: employees.map(emp => emp.empId) },
      $or: [
        { inTime: { $gte: startDate, $lte: endDate } }, // Sessions that started in our range
        {
          inTime: { $lt: startDate }, // Sessions that started before our range
          outTime: { $gte: startDate, $lte: endDate } // But ended in our range (night shifts from previous day)
        }
      ]
    }).lean();
    console.log('[getMonthlyAttendanceSummary] Found sessions:', allSessions.length);

    const results = [];
    console.log('[getMonthlyAttendanceSummary] Processing employees');
    for (const emp of employees) {
      try {
        const workerType = getWorkerType(emp);
        const weeklyOffDay = emp.shiftDetails?.weeklyOff || null;
        const daily = {};

        // Get employee sessions
        const empSessions = allSessions.filter(s => s.employeeId === emp.empId);

        // Calculate OT hours for this employee (only for fullMonth employees)
        let totalOtHours = 0;
        if (emp.employeeType === 'fullMonth') {
          for (const session of empSessions) {
            if (session.inTime && session.outTime) {
              const workHours = (new Date(session.outTime) - new Date(session.inTime)) / (1000 * 60 * 60);
              const standardHours = emp.shiftDetails?.workHoursPerDay || 9;
              // Round down OT hours to nearest whole hour
              if (workHours > standardHours) {
                totalOtHours += Math.floor(workHours - standardHours);
              }
            }
          }
        }

        // Process each day of the month
        for (let d = 1; d <= daysInMonth; d++) {
          const dateObj = new Date(year, monthNum - 1, d);
          const dateStr = dateObj.toISOString().slice(0, 10);

          // 1. Check for PH
          if (phDates.includes(dateStr)) {
            daily[d] = { code: 'PH' };
            continue;
          }

          // 2. Check for Leave
          const leaveType = leaveMap[emp.empId]?.[d];
          if (leaveType) {
            daily[d] = { code: leaveType };
            continue;
          }

          // 3. Check for Weekly Off - Only for weeklyOff and weeklyOffWithCoff employee types
          // Full month employees work on all days including Sundays
          const isWeeklyOffEmployee = emp.employeeType === 'weeklyOff' || emp.employeeType === 'weeklyOffWithCoff';
          if (isWeeklyOffEmployee && weeklyOffDay && dateObj.toLocaleString('en-US', { weekday: 'long' }) === weeklyOffDay) {
            daily[d] = { code: 'WO' };
            continue;
          }

          // 4. Check sessions for this day
          // For night shifts, we only show 'P' on the IN date, not the OUT date
          // Check for sessions that started on this day
          const sessionsForDay = empSessions.filter(session => {
            if (!session.inTime) return false;
            const sessionDate = new Date(session.inTime);
            return sessionDate.getDate() === d &&
              sessionDate.getMonth() === monthNum - 1 &&
              sessionDate.getFullYear() === year;
          });

          // Check for night shift sessions that end on this day
          // These should NOT be marked as present on this day
          let isNightShiftEndDate = false;
          for (const session of empSessions) {
            if (session.inTime && session.outTime) {
              const inTime = new Date(session.inTime);
              const outTime = new Date(session.outTime);

              // Check if IN and OUT are on different dates
              const inDateStr = inTime.toISOString().slice(0, 10);
              const outDateStr = outTime.toISOString().slice(0, 10);

              // Calculate session duration in hours
              const sessionDuration = (outTime - inTime) / (1000 * 60 * 60);

              // If this is a night shift with duration < 24 hours and the OUT date matches current date
              if (inDateStr !== outDateStr && sessionDuration < 24 && outDateStr === dateStr) {
                isNightShiftEndDate = true;
                break;
              }
            }
          }

          // If any session started on this day and it's not a night shift end date, show 'P'
          if (sessionsForDay.length > 0 && !isNightShiftEndDate) {
            daily[d] = { code: 'P' };
          } else {
            daily[d] = { code: 'A' };
          }
        }

        results.push({
          empId: emp.empId,
          name: `${emp.firstName} ${emp.lastName}`,
          department: emp.department,
          designation: emp.designation,
          fixedSalary: emp.monthlySalary,
          daily,
          leaveConfig: emp.leaveConfig || {},
          shiftDetails: emp.shiftDetails || {},
          workerType,
          otHours: Math.round(totalOtHours * 10) / 10 // Round to 1 decimal place
        });
      } catch (empError) {
        console.error(`[getMonthlyAttendanceSummary] Error processing employee ${emp.empId}:`, empError);
      }
    }
    console.log('[getMonthlyAttendanceSummary] Processing complete, returning results:', results.length);

    // Handle internal call differently from HTTP request
    if (isInternalCall) {
      return results;
    } else {
      // Check if res has json method before calling it
      if (res && typeof res.json === 'function') {
        res.json({ data: results });
      } else {
        // If res doesn't have json method, we're likely in an internal call context
        return results;
      }
    }
  } catch (err) {
    console.error("[getMonthlyAttendanceSummary] Error:", err);
    console.error("[getMonthlyAttendanceSummary] Error stack:", err.stack);
    if (isInternalCall) {
      throw err;
    } else {
      // Check if res has the status method before calling it
      if (res && typeof res.status === 'function') {
        res.status(500).json({ error: "Server error", message: err.message });
      } else {
        // If res doesn't have status method, we're likely in an internal call context
        throw err;
      }
    }
  }
};

// Get monthly payroll summary for all employees
export async function getMonthlyPayrollSummary(req, res) {
  try {
    const { month } = req.query;
    if (!month) {
      return res.status(400).json({ error: "Month is required (YYYY-MM)" });
    }

    const [year, monthNum] = month.split('-').map(Number);
    if (!year || !monthNum) {
      return res.status(400).json({ error: "Invalid month format. Use YYYY-MM" });
    }

    // Use the existing calculatePayroll function
    const payrollData = await calculatePayroll({ month: monthNum, year });

    return res.status(200).json({ data: payrollData });
  } catch (err) {
    console.error("Monthly payroll summary error:", err);
    return res.status(500).json({ error: "Server error" });
  }
};



// Utility function to detect worker type and classify days
function getWorkerType(emp) {
  // 8hr with weekly off
  if (emp.shiftDetails?.workHoursPerDay === 8 && emp.shiftDetails?.weeklyOff) {
    return '8hr_weeklyoff';
  }
  // 8hr without weekly off, C-OFF eligible
  if (emp.shiftDetails?.workHoursPerDay === 8 && emp.leaveConfig?.COFF !== undefined) {
    return '8hr_coff';
  }
  // 8hr without weekly off, OT eligible
  if (emp.shiftDetails?.workHoursPerDay === 8 && emp.leaveConfig?.COFF === undefined) {
    return '8hr_ot';
  }
  // 12hr worker
  if (emp.shiftDetails?.workHoursPerDay === 12) {
    return '12hr';
  }
  return 'unknown';
}

// Timeout function (if needed)
export const withTimeout = (res, timeoutMs = 60000) => {

  // Check if res is a valid Express response object
  if (!res || typeof res.status !== "function" || typeof res.headersSent === "undefined") {
    console.warn("withTimeout called with invalid res object. Timeout disabled.");
    return null;
  }

  const timer = setTimeout(() => {
    try {
      if (!res.headersSent) {
        res.status(504).json({ error: 'Request timed out' });
      }
    } catch (err) {
      console.error("Timeout handler failed:", err.message);
    }
  }, timeoutMs);

  // Auto-clear when finished
  res.on('finish', () => clearTimeout(timer));
  res.on('close', () => clearTimeout(timer));

  return timer;
};
